# Kopiere diese Datei nach .env und trage deine echten Werte ein.

# ── Server ────────────────────────────────────────────────
PORT=3000
FRONTEND_URL=http://localhost:5500

# ── MySQL (gleiche Daten wie in MySQL Workbench) ──────────
DB_HOST=localhost
DB_PORT=3307
DB_USER=root
DB_PASSWORD=dein_mysql_passwort
DB_NAME=phoenix

# ── Sessions ──────────────────────────────────────────────
# Beliebig lange zufällige Zeichenkette
SESSION_SECRET=irgendein_langer_zufaelliger_string_hier_eintragen

# ── Google OAuth ──────────────────────────────────────────
# Holst du dir bei https://console.cloud.google.com
# (siehe SETUP.md für Schritt-für-Schritt-Anleitung)
GOOGLE_CLIENT_ID=deine_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=dein_client_secret
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback
